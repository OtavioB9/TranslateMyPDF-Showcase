# Configurações do Provedor de Tradução
# ------------------------------------
# Chave de autenticação para DeepL API (Pro ou Free)
DEEPL_AUTH_KEY=your_deepl_api_key_here

# Credenciais do Google Cloud Translation (Caminho para o arquivo JSON)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/google-credentials.json

# Configurações do Servidor
# ------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Diretórios de Dados (Relativos à raiz do projeto)
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/output
DATABASE_PATH=translations.db
FONTS_DIR=fonts
